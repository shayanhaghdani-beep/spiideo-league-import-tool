# Copy to .env and edit. Everything is optional — the defaults work out of the
# box. Values already in your real environment win over this file.

# --- sf CLI backend (--source sf) -----------------------------------------
# Target org alias (see `sf org list`). Default: spiideo
# SF_TARGET_ORG=spiideo
# API name of the Account "Org Type" field on your org. The live Spiideo org
# uses Org_Type_for_Calc__c (NOT Org_Type__c). Check with:
#   sf sobject describe --sobject Account
# SF_ACCOUNT_ORGTYPE_FIELD=Org_Type_for_Calc__c

# --- local CSV backend (--source csv) -------------------------------------
# Override lookup file locations (defaults are under data/).
# SF_ACCOUNTS_CSV=./data/sf_accounts.csv
# USERS_CSV=./data/users.csv
# HUBSPOT_LEAGUES_CSV=./data/hubspot_leagues.csv
# HUBSPOT_COMPANY_IDS_CSV=./data/hubspot_company_ids.csv
# LEAGUE_DEAL_ALIASES_CSV=./data/league_deal_aliases.csv
# MANUAL_ACCOUNT_IDS_CSV=./data/manual_account_ids.csv

# --- behaviour ------------------------------------------------------------
# Opportunity currency for league deals. Default: EUR
# LEAGUE_OPP_CURRENCY=EUR
# Which Org_Type values count as "league" candidates (comma-separated).
# Default: league, conference, federation, association
# LOOKUP_LEAGUE_ORG_TYPES=League,Conference,Federation,Association
# Map a rep's short name in the sheet to their exact SF Full Name.
# REP_NAME_ALIASES=Freddy=Federico Caini, Brana=Branislav Lazic

# --- header overrides for CSV exports (rarely needed) ---------------------
# If your sf_accounts.csv / users.csv use non-standard headers:
# LOOKUP_ACCOUNTS_ID_HEADER=Salesforce Account ID
# LOOKUP_USERS_NAME_HEADER=Rep Name
